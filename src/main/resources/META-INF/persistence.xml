<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="ToolSuitePU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <!-- 实体类 -->
        <class>io.github.lemostic.toolsuite.modules.devops.deploy.entity.ServerConfigEntity</class>
        <class>io.github.lemostic.toolsuite.modules.devops.deploy.entity.DeploymentHistoryEntity</class>
        
        <properties>
            <!-- 这些属性将在代码中动态设置 -->
        </properties>
    </persistence-unit>
</persistence>
